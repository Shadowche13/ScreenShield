<Window x:Class="ScreenShield.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ScreenShield" Height="640" Width="1040"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/Assets/shield.png"
        Background="{DynamicResource WindowBackgroundBrush}" Foreground="{DynamicResource WindowForegroundBrush}"
        FontFamily="Segoe UI" Padding="12">

    <Window.Resources>
        <!-- Themeable brushes -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#0f0f10"/>
        <SolidColorBrush x:Key="WindowForegroundBrush" Color="White"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#131313"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#2a2a2a"/>
        <SolidColorBrush x:Key="LeftNavBackgroundBrush" Color="#111214"/>
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#101112"/>
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#3A9AD9"/>
        <SolidColorBrush x:Key="MutedForegroundBrush" Color="#8d8d8d"/>

        <!-- Pill button style -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background" Value="#262626"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                BorderBrush="{TemplateBinding BorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.995" ScaleY="0.995"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toggle pill visual -->
        <Style x:Key="TogglePillButton" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="120" Height="44">
                            <Border x:Name="bg" CornerRadius="22" Background="#2b2b2b" BorderBrush="#3a3a3a" BorderThickness="1"/>
                            <Grid Margin="6,6,6,6">
                                <Ellipse x:Name="knob" Width="32" Height="32" Fill="#cfcfcf" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="stateText" Text="{TemplateBinding Content}" Foreground="#888" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="knob" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Language ComboBox template (expands to content) -->
        <Style TargetType="ComboBox" x:Key="DarkComboBox">
            <Setter Property="Foreground" Value="#ddd"/>
            <Setter Property="Background" Value="{DynamicResource ControlBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="#222"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                <DockPanel>
                                    <ContentPresenter Margin="4,0,4,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" />
                                    <Path DockPanel.Dock="Right" Data="M 0 0 L 8 0 L 4 5 Z" Fill="#8aa7ff" Width="12" Height="8" Margin="6,0,6,0" VerticalAlignment="Center"/>
                                </DockPanel>
                            </Border>
                            <Popup Name="PART_Popup" Placement="Bottom" AllowsTransparency="True" Focusable="False" IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="{DynamicResource ControlBackgroundBrush}" CornerRadius="6" BorderBrush="#222" BorderThickness="1" Padding="6">
                                    <StackPanel>
                                        <ItemsPresenter/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Background="{DynamicResource LeftNavBackgroundBrush}" CornerRadius="10" Margin="0,0,12,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="88"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Brand: image logo above title -->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="12,8,12,8">
                    <Image Source="pack://application:,,,/Assets/shield.png"
                           Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock x:Name="appTitle" Text="SCREENSHIELD" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Menu -->
                <StackPanel Grid.Row="1" Margin="8,6,8,12">
                    <Button x:Name="menuDashboard" Content="Dashboard" Click="Menu_Click" Tag="0" Background="#161616" Foreground="White" BorderThickness="0" Padding="12,10" HorizontalContentAlignment="Left" FontSize="14" FontWeight="SemiBold" Margin="6,6,6,6"/>
                    <Button x:Name="menuStats" Content="Statistics" Click="Menu_Click" Tag="1" Background="Transparent" Foreground="#9a9a9a" BorderThickness="0" Padding="12,10" HorizontalContentAlignment="Left" FontSize="14" Margin="6,6,6,6"/>
                    <Button x:Name="menuSettings" Content="Settings" Click="Menu_Click" Tag="2" Background="Transparent" Foreground="#9a9a9a" BorderThickness="0" Padding="12,10" HorizontalContentAlignment="Left" FontSize="14" Margin="6,6,6,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TabControl x:Name="MainTabs" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="12">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- Dashboard -->
                <TabItem>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Vertical" Margin="12,10,12,12">
                            <!-- Parental Access card -->
                            <Border Style="{StaticResource Card}" Margin="0,0,0,18">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock x:Name="lblParentalAccess" Text="🔒 PARENTAL ACCESS" FontWeight="Bold" Foreground="#f4b648" FontSize="13"/>
                                    <TextBlock x:Name="lblEnterPassword" Text="Enter Admin Password" Foreground="{DynamicResource MutedForegroundBrush}" Grid.Row="1" Margin="0,8,0,6" FontSize="12"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,28,0,0">
                                        <TextBox x:Name="txtPassword" Width="420" Height="36" Background="{DynamicResource ControlBackgroundBrush}" Foreground="{DynamicResource WindowForegroundBrush}" BorderBrush="#222" Padding="10" VerticalContentAlignment="Center" Text="" />
                                        <Button x:Name="btnUnlock" Content="UNLOCK" Style="{StaticResource PillButton}" Width="160" Height="38" Margin="16,0,0,0" Click="btnUnlock_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Shield control card -->
                            <Border Style="{StaticResource Card}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="260"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Circular visualization (placeholder) -->
                                    <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse Width="160" Height="160" Stroke="#262626" StrokeThickness="12" Opacity="0.9"/>
                                        <TextBlock x:Name="lblActivePercent" Text="--%" FontSize="20" FontWeight="Bold" Foreground="#bdbdbd" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Grid>

                                    <StackPanel Grid.Column="1" Margin="18,10,18,10" VerticalAlignment="Center">
                                        <TextBlock x:Name="lblShieldControl" Text="SHIELD CONTROL" FontWeight="Bold" Foreground="#9aa0a6" FontSize="13" Margin="0,0,0,6"/>
                                        <TextBlock x:Name="lblStatus" Text="Shield control (Locked)" Foreground="#9a9a9a" FontWeight="Bold" FontSize="13" Margin="0,0,0,12"/>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
                                            <TextBlock x:Name="lblIntensityText" Text="Intensity" VerticalAlignment="Center" Foreground="#bdbdbd" Width="80"/>
                                            <Slider x:Name="sliderIntensity" Minimum="10" Maximum="100" Value="50" IsEnabled="False" Width="260" ValueChanged="sliderIntensity_ValueChanged"/>
                                            <TextBlock x:Name="txtIntensityValue" Text="50%" Width="48" Margin="8,0,0,0" Foreground="#bdbdbd" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,0,0">
                                            <Button x:Name="btnToggle" Content="OFF" Click="btnToggle_Click" IsEnabled="False" Style="{StaticResource TogglePillButton}" />
                                            <Button x:Name="btnGamingMode" Content="GAMING MODE" Width="140" Height="36" Margin="12,0,0,0" Style="{StaticResource PillButton}" IsEnabled="False" Click="btnGamingMode_Click"/>
                                            <Button x:Name="btnArtistMode" Content="ARTIST MODE" Width="140" Height="36" Margin="12,0,0,0" Style="{StaticResource PillButton}" IsEnabled="False" Click="btnArtistMode_Click"/>
                                        </StackPanel>

                                        <TextBlock x:Name="lblShieldHint" Text="Enter password to unlock shield controls." Foreground="{DynamicResource MutedForegroundBrush}" Margin="0,12,0,0" FontSize="12"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Stats -->
                <TabItem>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock x:Name="lblStatsTitle" Text="📊 SCREEN TIME" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,0,0,8"/>
                            <TextBlock x:Name="lblStatsTime" Text="Screen time today: 0m 0s" Foreground="#bdbdbd"/>
                            <TextBlock x:Name="lblStatsSaved" Text="Eye strain saved: Optimal" Foreground="LightGreen" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </TabItem>

                <!-- Settings -->
                <TabItem>
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock x:Name="lblSettingsTitle" Text="⚙️ SETTINGS" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PrimaryAccentBrush}" Margin="0,0,0,12"/>
                            <TextBlock x:Name="lblLanguageSelect" Text="Select language:" Foreground="#bdbdbd" Margin="0,0,0,6"/>
                            <ComboBox x:Name="comboLanguage" Width="380" SelectionChanged="ComboLanguage_SelectionChanged" Style="{StaticResource DarkComboBox}">
                                <ComboBoxItem Tag="bg">Български (BG)</ComboBoxItem>
                                <ComboBoxItem Tag="en">English (EN)</ComboBoxItem>
                                <ComboBoxItem Tag="ru">Русский (RU)</ComboBoxItem>
                                <ComboBoxItem Tag="tr">Türkçe (TR)</ComboBoxItem>
                                <ComboBoxItem Tag="de">Deutsch (DE)</ComboBoxItem>
                                <ComboBoxItem Tag="ar">العربية (AR)</ComboBoxItem>
                                <ComboBoxItem Tag="zh">中文 (ZH)</ComboBoxItem>
                                <ComboBoxItem Tag="ja">日本語 (JA)</ComboBoxItem>
                                <ComboBoxItem Tag="es">Español (ES)</ComboBoxItem>
                            </ComboBox>

                            <!-- Theme chooser -->
                            <TextBlock Text="Theme:" Margin="0,12,0,6" Foreground="#bdbdbd"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="btnThemeDark" Tag="dark" Click="btnTheme_Click" Style="{StaticResource PillButton}" Width="120" Height="36" Margin="0,0,8,0">Dark</Button>
                                <Button x:Name="btnThemeLight" Tag="light" Click="btnTheme_Click" Style="{StaticResource PillButton}" Width="120" Height="36">Light</Button>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</Window>